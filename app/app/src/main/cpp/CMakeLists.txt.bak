cmake_minimum_required(VERSION 3.10)
project(lwpbridge C CXX ASM)

add_library(lwpbridge SHARED
        lwpbridge_jni.c
        elf_exports.c
        ffi_call_arm32.S
)

target_compile_features(lwpbridge PRIVATE c_std_11)

target_include_directories(lwpbridge PRIVATE ${CMAKE_CURRENT_SOURCE_DIR})

target_link_libraries(lwpbridge
        android
        log
        dl
)

# Proxy replacement for liblwplocal.so
# - JNI entrypoints are implemented here
# - forward calls into liblwplocal_orig.so (packaged in jniLibs)
add_library(lwplocal SHARED
        lwplocal_proxy.cpp
)

target_compile_features(lwplocal PRIVATE cxx_std_17)

target_link_libraries(lwplocal
        log
        dl
)
